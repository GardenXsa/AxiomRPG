{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LocationDefinition",
  "description": "Defines a location in the world. Cities, villages, dungeons, caves - NOT points on a map, but actual multi-chunk structures.",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "type": { "type": "string", "enum": ["city", "village", "town", "dungeon", "cave", "ruins", "camp", "fortress", "temple", "tower"] },
    "biomeId": { "type": "string" },
    "districts": { "type": "array", "items": { "type": "string" }, "description": "District/area names within this location" },
    "structures": { "type": "array", "items": { "type": "string" }, "description": "Structure IDs within this location" },
    "connections": { "type": "array", "items": { "type": "string" }, "description": "Connected location IDs (roads, passages)" },
    "sizeX": { "type": "integer", "description": "Width in chunks" },
    "sizeY": { "type": "integer", "description": "Height in chunks" },
    "properties": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "required": ["id", "name", "type"]
}

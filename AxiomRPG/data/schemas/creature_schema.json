{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreatureTemplateDefinition",
  "description": "Defines a creature template. All creatures (NPCs, monsters, animals) are instances of templates.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "Unique template ID" },
    "name": { "type": "string", "description": "Creature display name" },
    "description": { "type": "string", "description": "Detailed creature description" },
    "category": { "type": "string", "enum": ["humanoid", "beast", "undead", "construct", "elemental", "plant", "dragon", "demon"], "description": "Creature category" },
    "race": { "type": "string", "description": "Race identifier" },
    "size": { "type": "string", "enum": ["tiny", "small", "medium", "large", "huge"], "description": "Creature size category" },
    "defaultBehavior": { "type": "string", "enum": ["idle", "wander", "patrol", "aggressive", "flee", "pack_predator", "territorial", "merchant"], "description": "Default AI behavior type" },
    "asciiChar": { "type": "string", "maxLength": 1, "description": "Single ASCII character for rendering" },
    "foregroundColor": { "type": "string", "description": "Hex color for ASCII character" },
    "backgroundColor": { "type": "string", "description": "Hex background color" },
    "baseStats": { "type": "object", "additionalProperties": { "type": "number" }, "description": "Base stat values from the world's stat system" },
    "abilities": { "type": "array", "items": { "type": "string" }, "description": "Ability identifiers this creature has" },
    "naturalDrops": { "type": "array", "items": { "type": "string" }, "description": "Item IDs this creature drops on death" },
    "factionId": { "type": ["string", "null"], "description": "Faction this creature belongs to" },
    "properties": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Additional custom properties" }
  },
  "required": ["id", "name", "category"]
}

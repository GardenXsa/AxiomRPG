{
  "id": "standard_rpg",
  "name": "Standard RPG Stat System",
  "stats": [
    { "name": "str", "displayName": "Strength", "description": "Physical power and melee damage", "minValue": 1, "maxValue": 30, "defaultValue": 10, "category": "physical" },
    { "name": "dex", "displayName": "Dexterity", "description": "Agility, reflexes and ranged accuracy", "minValue": 1, "maxValue": 30, "defaultValue": 10, "category": "physical" },
    { "name": "con", "displayName": "Constitution", "description": "Endurance and hit points", "minValue": 1, "maxValue": 30, "defaultValue": 10, "category": "physical" },
    { "name": "int", "displayName": "Intelligence", "description": "Knowledge and magical power", "minValue": 1, "maxValue": 30, "defaultValue": 10, "category": "mental" },
    { "name": "wis", "displayName": "Wisdom", "description": "Perception and willpower", "minValue": 1, "maxValue": 30, "defaultValue": 10, "category": "mental" },
    { "name": "cha", "displayName": "Charisma", "description": "Social influence and leadership", "minValue": 1, "maxValue": 30, "defaultValue": 10, "category": "social" }
  ],
  "customIndicators": [
    { "name": "sanity", "displayName": "Sanity", "description": "Mental stability — drops when encountering horror", "minValue": 0, "maxValue": 100, "defaultValue": 100, "decayRate": "0.01/tick", "affectedBy": "horror_encounters, dark_magic, rest" },
    { "name": "corruption", "displayName": "Corruption", "description": "Dark influence on the soul — grows from forbidden acts", "minValue": 0, "maxValue": 100, "defaultValue": 0, "decayRate": "none", "affectedBy": "dark_rituals, cursed_items, forbidden_knowledge" },
    { "name": "fame", "displayName": "Fame", "description": "Reputation across the land — affects NPC reactions", "minValue": -100, "maxValue": 100, "defaultValue": 0, "decayRate": "0.005/tick", "affectedBy": "quests_completed, heroic_acts, villainous_acts" },
    { "name": "hunger", "displayName": "Hunger", "description": "Need for food — penalties when too high", "minValue": 0, "maxValue": 100, "defaultValue": 0, "decayRate": "0.1/tick", "affectedBy": "eating, fasting, activity" },
    { "name": "thirst", "displayName": "Thirst", "description": "Need for water — more urgent than hunger", "minValue": 0, "maxValue": 100, "defaultValue": 0, "decayRate": "0.15/tick", "affectedBy": "drinking, activity, temperature" }
  ],
  "derivedStats": [
    { "name": "max_hp", "displayName": "Max HP", "formula": "con * 5 + str * 2", "dependencies": ["con", "str"] },
    { "name": "max_stamina", "displayName": "Max Stamina", "formula": "con * 3 + dex * 2", "dependencies": ["con", "dex"] },
    { "name": "initiative", "displayName": "Initiative", "formula": "dex + wis / 2", "dependencies": ["dex", "wis"] },
    { "name": "dodge_chance", "displayName": "Dodge Chance", "formula": "dex * 2", "dependencies": ["dex"] },
    { "name": "carry_capacity", "displayName": "Carry Capacity", "formula": "str * 5 + con * 2", "dependencies": ["str", "con"] }
  ],
  "properties": {}
}
